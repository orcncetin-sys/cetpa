# ── Cargo Tracking ──────────────────────────────────────────────────────────
# Without these keys the tracking tab shows clearly-labeled DEMO results.
DHL_API_KEY=
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=

# ── Luca e-Fatura Entegrasyonu ───────────────────────────────────────────────
# Required for GİB VKN lookup, kontör balance, and e-invoice sending.
LUCA_API_KEY=
LUCA_API_URL=https://api.luca.com.tr/v1
LUCA_COMPANY_ID=

# ── Exchange Rates ────────────────────────────────────────────────────────────
# Optional: free tier used automatically, then TCMB XML as fallback.
EXCHANGE_RATE_API_KEY=

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ── Firebase Admin SDK (server-side webhook writes) ───────────────────────────
# Local dev: run `gcloud auth application-default login`
# OR: GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Cloud Run / Firebase Hosting: automatic (ADC)

# ── Mikro Jump API ────────────────────────────────────────────────────────────
# Auth: IDM (Online İşlem Merkezi) credentials — used to get the Bearer token
# Token endpoint: https://onlinekullanici.mikro.com.tr/auth/realms/Mikro/...
MIKRO_IDM_EMAIL=orcun@cetpa.com.tr
MIKRO_IDM_PASSWORD=           # "1234***" password from Online İşlem Merkezi

# API Gateway (whitelisted IP required — calls must come from this server)
MIKRO_API_URL=https://jumpbulutapigw.mikro.com.tr/ApiJB/ApiMethods

# Mikro context — included in every API request body
MIKRO_ALIAS=                  # e.g. XCXY-8332 (from Mikro portal)
MIKRO_FIRMA_KODU=01
MIKRO_CALISMA_YILI=2026
MIKRO_API_KEY=                # ApiKey from Mikro portal
MIKRO_KULLANICI_KODU=SRV
MIKRO_SIFRE=                  # MD5-hashed server user password
MIKRO_FIRMA_NO=0
MIKRO_SUBE_NO=0

# Set to "true" to enable hourly stok+cari sync cron job
MIKRO_CRON_SYNC=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5173
NODE_ENV=development
