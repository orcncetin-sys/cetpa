# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase Web App (recommended for local dev; overrides firebase-applet-config.json when set)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SHOPIFY_API_KEY: Admin API Access Token for Shopify.
# Get this from Shopify Admin > Apps > Develop Apps.
SHOPIFY_API_KEY="MY_SHOPIFY_API_KEY"

# SHOPIFY_STORE_URL: The URL of your Shopify store (e.g., cetpa-com-tr.myshopify.com).
SHOPIFY_STORE_URL="cetpa-com-tr.myshopify.com"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps API calls.
# Get this from Google Cloud Console > APIs & Services > Credentials.
GOOGLE_MAPS_PLATFORM_KEY="MY_GOOGLE_MAPS_PLATFORM_KEY"

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# SMS Fallback (Netgsm)
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_HEADER=CETPA

# Exchange Rate API
EXCHANGE_RATE_API_KEY=
